generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  isCompleted Boolean @default(false)
}

model Contact {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  phone String
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}